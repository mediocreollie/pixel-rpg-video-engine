{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "character.schema.json",
  "title": "Character",
  "type": "object",
  "required": ["id", "name", "sprite", "movementSpeed", "dialogueColor", "emotes"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "sprite": {
      "type": "object",
      "required": ["asset"],
      "properties": {
        "asset": { "type": "string" },
        "path": { "type": "string" },
        "shirtColor": { "type": "string" },
        "faceColor": { "type": "string" }
      }
    },
    "portrait": {
      "type": "object",
      "properties": {
        "asset": { "type": "string" },
        "path": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "shirtColor": { "type": "string" },
        "faceColor": { "type": "string" },
        "hairColor": { "type": "string" }
      }
    },
    "movementSpeed": { "type": "number" },
    "dialogueColor": { "type": "string" },
    "emotes": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
