{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "location.schema.json",
  "title": "Location",
  "type": "object",
  "required": ["id", "mapName", "exits", "props", "npcSpawnPoints", "map"],
  "properties": {
    "id": { "type": "string" },
    "mapName": { "type": "string" },
    "background": { "type": "string" },
    "musicPath": { "type": "string" },
    "ambiencePath": { "type": "string" },
    "tileSize": { "type": "number" },
    "width": { "type": "number" },
    "height": { "type": "number" },
    "assetPacks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "propAssetPack": { "type": "string" },
    "cameraZoom": { "type": "number" },
    "playerScale": { "type": "number" },
    "propScaleMultiplier": { "type": "number" },
    "display": {
      "type": "object",
      "properties": {
        "cameraZoom": { "type": "number" },
        "playerScale": { "type": "number" },
        "propScaleMultiplier": { "type": "number" },
        "cameraMode": { "type": "string" }
      }
    },
    "playerSpawnPoint": { "type": "string" },
    "playerSpawns": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "exits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x", "y", "targetLocation"],
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "targetLocation": { "type": "string" },
          "spawnPoint": { "type": "string" },
          "width": { "type": "number" },
          "height": { "type": "number" }
        }
      }
    },
    "props": {
      "type": "array",
      "items": { "type": "object" }
    },
    "npcSpawnPoints": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "map": {
      "type": "object",
      "required": ["legend", "tiles"],
      "properties": {
        "legend": { "type": "object" },
        "tiles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "terrain": {
      "type": "object",
      "properties": {
        "tileSize": { "type": "number" },
        "base": { "type": "string" },
        "rows": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "layers": {
      "type": "object",
      "properties": {
        "terrain": {
          "type": "object",
          "properties": {
            "tileSize": { "type": "number" },
            "legend": { "type": "object" },
            "rows": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "object",
          "properties": {
            "legend": { "type": "object" },
            "rows": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "boundaries": {
          "type": "array",
          "items": { "type": "object" }
        },
        "props": {
          "type": "array",
          "items": { "type": "object" }
        },
        "overPlayer": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "collision": {
      "type": "object",
      "properties": {
        "fromTerrain": { "type": "boolean" },
        "fromFootprints": { "type": "boolean" },
        "rects": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "triggers": {
      "type": "array",
      "items": { "type": "object" }
    },
    "spawns": {
      "type": "object",
      "properties": {
        "player": { "type": "object" },
        "npcs": { "type": "object" }
      }
    }
  }
}
